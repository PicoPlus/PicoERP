@inject NavigationManager Nav

<div class="pico-nav">
    <!-- Logo header -->
    <div style="display:flex;align-items:center;gap:10px;padding:18px 14px 12px;margin-bottom:4px;">
        <div style="width:38px;height:38px;border-radius:10px;background:linear-gradient(135deg,#1565C0,#0091AE);display:flex;align-items:center;justify-content:center;flex-shrink:0;box-shadow:0 4px 12px rgba(21,101,192,.3);">
            <img src="/logo.svg" alt="PicoERP" style="height:24px;width:24px;filter:brightness(0) invert(1);" />
        </div>
        <div>
            <div style="font-weight:800;font-size:15px;color:var(--mud-palette-text-primary);letter-spacing:-.3px;">پیکو ERP</div>
            <div style="font-size:11px;color:var(--mud-palette-text-secondary);margin-top:1px;">سیستم مدیریت کافه‌نت</div>
        </div>
    </div>

    <NavItem Href="/" Icon="@Icons.Material.Filled.Dashboard" Label="داشبورد" />

    <div class="nav-group-header">💰 مالی</div>
    <NavItem Href="/incomes"              Icon="@Icons.Material.Filled.TrendingUp"    Label="درآمدها" />
    <NavItem Href="/expenses"             Icon="@Icons.Material.Filled.TrendingDown"  Label="هزینه‌ها" />
    <NavItem Href="/accounts"             Icon="@Icons.Material.Filled.AccountBalance" Label="حساب‌های مالی" />
    <NavItem Href="/daily-closing"        Icon="@Icons.Material.Filled.Today"         Label="بستن روزانه" />
    <NavItem Href="/bank-transfers"       Icon="@Icons.Material.Filled.CompareArrows" Label="انتقالات بانکی" />
    <NavItem Href="/bank-statement-import" Icon="@Icons.Material.Filled.FileUpload"   Label="صورت‌حساب بانکی" />

    <div class="nav-group-header">👥 کارمندان</div>
    <NavItem Href="/employees" Icon="@Icons.Material.Filled.Badge"    Label="کارمندان" />
    <NavItem Href="/salaries"  Icon="@Icons.Material.Filled.Payments" Label="حقوق و دستمزد" />

    <div class="nav-group-header">🛒 خرید</div>
    <NavItem Href="/purchases" Icon="@Icons.Material.Filled.ShoppingCart" Label="خریدها" />

    <div class="nav-group-header">📊 گزارش‌ها</div>
    <NavItem Href="/reports/income"  Icon="@Icons.Material.Filled.BarChart"      Label="گزارش درآمد" />
    <NavItem Href="/reports/expense" Icon="@Icons.Material.Filled.PieChart"      Label="گزارش هزینه" />
    <NavItem Href="/reports/profit"  Icon="@Icons.Material.Filled.ShowChart"     Label="گزارش سود" />
    <NavItem Href="/reports/salary"  Icon="@Icons.Material.Filled.AssignmentInd" Label="گزارش حقوق" />

    <div class="nav-group-header">🤝 هاب‌اسپات CRM</div>
    <NavItem Href="/hubspot"  Icon="@Icons.Material.Filled.Cloud"     Label="داشبورد CRM" />
    <NavItem Href="/contacts"   Icon="@Icons.Material.Filled.People"         Label="مخاطبین" />
    <NavItem Href="/deals"      Icon="@Icons.Material.Filled.Handshake"      Label="دیل‌ها" />
    <NavItem Href="/zohal-logs" Icon="@Icons.Material.Filled.ManageSearch"   Label="لاگ استعلام هویت" />

    <div class="nav-group-header">💬 پیامک</div>
    <NavItem Href="/sms"          Icon="@Icons.Material.Filled.Sms"         Label="ارسال پیامک" />
    <NavItem Href="/sms/patterns" Icon="@Icons.Material.Filled.DynamicForm" Label="مدیریت پترن‌ها" />
    <NavItem Href="/sms/outbox"   Icon="@Icons.Material.Filled.Outbox"      Label="صندوق صادره" />

    <div class="nav-group-header">⚙️ مدیریت</div>
    <NavItem Href="/settings"  Icon="@Icons.Material.Filled.Settings"       Label="تنظیمات" />
    <NavItem Href="/backup"    Icon="@Icons.Material.Filled.Backup"         Label="پشتیبان‌گیری" />
    <NavItem Href="/users"     Icon="@Icons.Material.Filled.ManageAccounts" Label="کاربران" />
    <NavItem Href="/audit-log" Icon="@Icons.Material.Filled.History"        Label="گزارش فعالیت" />
</div>
