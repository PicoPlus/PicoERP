@using PicoERP.Application.DTOs
@using PicoERP.Application.Interfaces
@inject IHubSpotService HubSpotService
@inject IZohalService ZohalService
@inject MudBlazor.ISnackbar Snackbar

<MudDialog>
    <TitleContent>
        <div style="display:flex;align-items:center;gap:10px;">
            <MudIcon Icon="@Icons.Material.Filled.PersonAdd" Style="color:#FF7A59;" />
            <MudText Typo="Typo.h6">افزودن مخاطب جدید</MudText>
        </div>
    </TitleContent>
    <DialogContent>
        <MudForm @ref="_form" dir="rtl">
            <MudGrid Spacing="3">
                <MudItem xs="12" sm="6">
                    <MudTextField @bind-Value="_model.FirstName"
                                  Label="نام *"
                                  Variant="Variant.Outlined"
                                  Required="true"
                                  RequiredError="نام الزامی است" />
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudTextField @bind-Value="_model.LastName"
                                  Label="نام خانوادگی *"
                                  Variant="Variant.Outlined"
                                  Required="true"
                                  RequiredError="نام خانوادگی الزامی است" />
                </MudItem>
                <MudItem xs="12" sm="6">
                    <div style="display:flex;gap:6px;align-items:flex-start;">
                        <MudTextField @bind-Value="_model.NCode"
                                      Label="کد ملی"
                                      Variant="Variant.Outlined"
                                      Placeholder="مثال: ۱۲۳۴۵۶۷۸۹۰"
                                      Error="@(!string.IsNullOrEmpty(_ncodeError))"
                                      ErrorText="@_ncodeError"
                                      Style="flex:1;" />
                        <MudTooltip Text="استعلام هویت از ثبت‌احوال (زهل)">
                            <MudIconButton Icon="@Icons.Material.Filled.ManageSearch"
                                           Color="Color.Info"
                                           Variant="Variant.Outlined"
                                           Size="Size.Medium"
                                           Style="margin-top:4px;flex-shrink:0;"
                                           Disabled="@(string.IsNullOrWhiteSpace(_model.NCode) || string.IsNullOrWhiteSpace(_model.BirthDate) || _inquiring)"
                                           OnClick="RunInquiry" />
                        </MudTooltip>
                    </div>
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudTextField @bind-Value="_model.MobilePhone"
                                  Label="تلفن همراه"
                                  Variant="Variant.Outlined"
                                  Placeholder="مثال: ۰۹۱۲۱۲۳۴۵۶۷"
                                  Error="@(!string.IsNullOrEmpty(_mobileError))"
                                  ErrorText="@_mobileError" />
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudTextField @bind-Value="_model.FatherName"
                                  Label="نام پدر"
                                  Variant="Variant.Outlined" />
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudTextField @bind-Value="_model.BirthDate"
                                  Label="تاریخ تولد"
                                  Variant="Variant.Outlined"
                                  Placeholder="مثال: ۱۳۷۰/۰۱/۰۱" />
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudTextField @bind-Value="_model.Email"
                                  Label="ایمیل"
                                  Variant="Variant.Outlined"
                                  InputType="InputType.Email" />
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudTextField @bind-Value="_model.Company"
                                  Label="شرکت"
                                  Variant="Variant.Outlined" />
                </MudItem>
            </MudGrid>

            @if (_inquiring)
            {
                <MudProgressLinear Color="Color.Info" Indeterminate="true" Class="mt-3" />
                <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mt-1">در حال استعلام از سامانه ثبت‌احوال...</MudText>
            }

            @if (_inquiryResult != null)
            {
                <MudAlert Severity="@(_inquiryResult.Matched == true ? Severity.Success : Severity.Warning)"
                          Class="mt-3" Dense="false" Icon="@(_inquiryResult.Matched == true ? Icons.Material.Filled.VerifiedUser : Icons.Material.Filled.GppBad)">
                    @if (!string.IsNullOrEmpty(_inquiryResult.Error))
                    {
                        <span>@_inquiryResult.Error</span>
                    }
                    else if (_inquiryResult.Matched == true)
                    {
                        <div style="display:flex;flex-direction:column;gap:2px;">
                            <strong>هویت تأیید شد ✓</strong>
                            <span>نام: @_inquiryResult.FirstName @_inquiryResult.LastName</span>
                            <span>نام پدر: @_inquiryResult.FatherName</span>
                            <span>وضعیت حیات: @(_inquiryResult.IsDead == true ? "فوت‌شده ✗" : "زنده ✓")</span>
                        </div>
                    }
                    else
                    {
                        <span>کد ملی و تاریخ تولد مطابقت ندارند</span>
                    }
                </MudAlert>
            }

            @if (!string.IsNullOrEmpty(_generalError))
            {
                <MudAlert Severity="Severity.Error" Class="mt-3" Dense="true">@_generalError</MudAlert>
            }
        </MudForm>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel" Variant="Variant.Text">انصراف</MudButton>
        <MudButton OnClick="Submit" Variant="Variant.Filled" Color="Color.Primary"
                   StartIcon="@Icons.Material.Filled.Save"
                   Disabled="@_saving">
            @(_saving ? "در حال ذخیره..." : "ذخیره مخاطب")
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; } = null!;
    [Parameter] public string ApiKey { get; set; } = string.Empty;

    private MudForm _form = null!;
    private CreateHubSpotContactDto _model = new();
    private bool _saving;
    private string _ncodeError    = "";
    private string _mobileError   = "";
    private string _generalError  = "";
    private bool   _inquiring;
    private ZohalIdentityResultDto? _inquiryResult;

    // ── Zohal identity inquiry ───────────────────────────────────────────────

    private async Task RunInquiry()
    {
        if (string.IsNullOrWhiteSpace(_model.NCode) || string.IsNullOrWhiteSpace(_model.BirthDate))
            return;

        _inquiring     = true;
        _inquiryResult = null;
        StateHasChanged();

        _inquiryResult = await ZohalService.InquireAsync(_model.NCode.Trim(), _model.BirthDate.Trim());

        // If matched, auto-fill name fields (only when they are currently empty)
        if (_inquiryResult.Matched == true)
        {
            if (string.IsNullOrWhiteSpace(_model.FirstName)  && !string.IsNullOrWhiteSpace(_inquiryResult.FirstName))
                _model.FirstName  = _inquiryResult.FirstName;
            if (string.IsNullOrWhiteSpace(_model.LastName)   && !string.IsNullOrWhiteSpace(_inquiryResult.LastName))
                _model.LastName   = _inquiryResult.LastName;
            if (string.IsNullOrWhiteSpace(_model.FatherName) && !string.IsNullOrWhiteSpace(_inquiryResult.FatherName))
                _model.FatherName = _inquiryResult.FatherName;
        }

        _inquiring = false;
    }

    private void Cancel() => MudDialog.Cancel();

    private async Task Submit()
    {
        await _form.Validate();
        if (!_form.IsValid) return;

        _ncodeError   = "";
        _mobileError  = "";
        _generalError = "";
        _saving       = true;

        try
        {
            // Uniqueness checks
            if (!string.IsNullOrWhiteSpace(_model.NCode))
            {
                var existId = await HubSpotService.FindContactByNcodeAsync(ApiKey, _model.NCode);
                if (existId != null)
                {
                    _ncodeError = "این کد ملی قبلاً در هاب‌اسپات ثبت شده است.";
                    return;
                }
            }

            if (!string.IsNullOrWhiteSpace(_model.MobilePhone))
            {
                var existId = await HubSpotService.FindContactByMobileAsync(ApiKey, _model.MobilePhone);
                if (existId != null)
                {
                    _mobileError = "این شماره موبایل قبلاً در هاب‌اسپات ثبت شده است.";
                    return;
                }
            }

            // Create in HubSpot
            var created = await HubSpotService.CreateContactAsync(ApiKey, _model);

            // Also save locally
            await HubSpotService.SaveContactLocallyAsync(new HubSpotContactDto
            {
                Id          = created.Id,
                FirstName   = _model.FirstName,
                LastName    = _model.LastName,
                Email       = _model.Email,
                Phone       = _model.MobilePhone,
                Company     = _model.Company,
                NCode       = _model.NCode,
                BirthDate   = _model.BirthDate,
                FatherName  = _model.FatherName,
                MobilePhone = _model.MobilePhone,
                CreateDate  = DateTime.UtcNow
            });

            MudDialog.Close(DialogResult.Ok(created));
        }
        catch (Exception ex)
        {
            _generalError = $"خطا در ایجاد مخاطب: {ex.Message}";
        }
        finally { _saving = false; }
    }
}
