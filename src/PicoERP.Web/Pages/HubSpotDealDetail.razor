    private string GetStageLabel(string? stageId)
    {
        if (string.IsNullOrWhiteSpace(stageId)) return "—";
        return _stages.FirstOrDefault(s => s.Id == stageId)?.Label ?? stageId;
    }

    private Color GetStageColor(string? stageId) => stageId switch
    {
        "closedwon"    => Color.Success,
        "closedlost"   => Color.Error,
        "contractsent" => Color.Warning,
        _              => Color.Primary
    };

    private string GetStageChipStyle(string? stageId) => stageId switch
    {
        "closedwon"  => "background:#dcfce7;color:#166534;",
        "closedlost" => "background:#fee2e2;color:#991b1b;",
        "contractsent" => "background:#fef9c3;color:#854d0e;",
        _ => "background:rgba(255,255,255,.22);color:#fff;"
    };

    private static string FormatFileSize(long bytes) =>
        bytes switch
        {
            < 1024                => $"{bytes} B",
            < 1024 * 1024         => $"{bytes / 1024.0:F1} KB",
            _                     => $"{bytes / (1024.0 * 1024):F1} MB"
        };

    private RenderFragment DealInfoCell(string label, string? value, string icon) => __builder =>
    {
        <div class="deal-info-cell">
            <div class="deal-info-label">
                <MudIcon Icon="@icon" Size="Size.Small" Style="vertical-align:middle;margin-left:3px;" />
                @label
            </div>
            <div class="deal-info-value" dir="ltr" style="text-align:right;">
                @(string.IsNullOrWhiteSpace(value) ? "—" : value)
            </div>
        </div>;
    };
}
