@page "/sms"
@inject AppStateService AppState
@inject ISmsService SmsService
@inject ISmsLogService SmsLogService
@inject IHubSpotService HubSpotService
@inject ISettingsService SettingsService
@inject ISnackbar Snackbar

<PageTitle>پیامک — پیکو ERP</PageTitle>

<div class="pico-page" dir="rtl">
    <div class="page-header">
        <MudText Typo="Typo.h4" Class="page-title">ارسال پیامک</MudText>
        <MudButton Variant="Variant.Outlined" Color="Color.Primary"
                   StartIcon="@Icons.Material.Filled.List"
                   Href="/sms/patterns">
            مدیریت پترن‌ها
        </MudButton>
    </div>

    <MudGrid Spacing="3">

        <!-- ── Compose Card ── -->
        <MudItem xs="12" md="5">
            <MudCard Elevation="2" Class="pico-card">
                <MudCardHeader>
                    <CardHeaderContent>
                        <MudText Typo="Typo.h6">
                            <MudIcon Icon="@Icons.Material.Filled.Send" Class="ml-2" />
                            ارسال پیامک جدید
                        </MudText>
                    </CardHeaderContent>
                </MudCardHeader>
                <MudCardContent>
                    <MudGrid Spacing="2">

                        <!-- Contact search -->
                        <MudItem xs="12">
                            <MudAutocomplete T="ContactSearchItem"
                                             Label="جستجو مخاطب (اختیاری)"
                                             Value="_selectedContact"
                                             ValueChanged="OnContactSelected"
                                             SearchFunc="SearchContacts"
                                             ToStringFunc="@(c => c?.Display ?? "")"
                                             Variant="Variant.Outlined"
                                             Clearable="true"
                                             AdornmentIcon="@Icons.Material.Filled.Search"
                                             Adornment="Adornment.End"
                                             HelperText="بعد از انتخاب مخاطب، شماره تلفن پر می‌شود" />
                        </MudItem>

                        <!-- Phone number -->
                        <MudItem xs="12">
                            <MudTextField @bind-Value="_toPhone"
                                          Label="شماره گیرنده"
                                          Variant="Variant.Outlined"
                                          Adornment="Adornment.Start"
                                          AdornmentIcon="@Icons.Material.Filled.PhoneAndroid"
                                          Placeholder="09123456789"
                                          Required="true" />
                        </MudItem>

                        <!-- Sender number selector -->
                        <MudItem xs="12">
                            <div style="display:flex;gap:6px;align-items:flex-start;">
                                <MudSelect @bind-Value="_smsSender"
                                           Label="سر شماره فرستنده"
                                           Variant="Variant.Outlined"
                                           Disabled="@_loadingNumbers"
                                           HelperText="@(_loadingNumbers ? "در حال بارگذاری..." : (_senderNumbers.Count == 0 ? "کلید API پیامک تنظیم نشده" : $"{_senderNumbers.Count} خط"))"
                                           AnchorOrigin="Origin.BottomLeft"
                                           Style="flex:1;">
                                    @foreach (var num in _senderNumbers)
                                    {
                                        <MudSelectItem Value="@num">@num</MudSelectItem>
                                    }
                                </MudSelect>
                                <MudTooltip Text="بارگذاری خطوط از آی‌پی‌پنل">
                                    <MudIconButton Icon="@Icons.Material.Filled.Refresh"
                                                   Variant="Variant.Outlined"
                                                   Color="Color.Primary"
                                                   Size="Size.Medium"
                                                   Disabled="@(_loadingNumbers || string.IsNullOrWhiteSpace(AppState.SmsApiKey))"
                                                   OnClick="LoadSenderNumbersAsync"
                                                   Style="margin-top:4px;" />
                                </MudTooltip>
                            </div>
                        </MudItem>

                        <!-- SMS type dropdown -->
                        <MudItem xs="12">
                            <MudSelect @bind-Value="_smsType"
                                       Label="نوع پیامک"
                                       Variant="Variant.Outlined"
                                       AnchorOrigin="Origin.BottomLeft">
                                <MudSelectItem Value="@SmsType.Webservice">پیامک عادی (Webservice)</MudSelectItem>
                                <MudSelectItem Value="@SmsType.Pattern">پترن (Pattern)</MudSelectItem>
                            </MudSelect>
                        </MudItem>

                        <!-- Webservice: message text -->
                        @if (_smsType == SmsType.Webservice)
                        {
                            <MudItem xs="12">
                                <MudTextField @bind-Value="_messageText"
                                              Label="متن پیامک"
                                              Variant="Variant.Outlined"
                                              Lines="4" AutoGrow="true"
                                              Placeholder="متن پیامک را وارد کنید..."
                                              HelperText="@($"{_messageText.Length} کاراکتر — حدود {Math.Ceiling(_messageText.Length / 70.0)} صفحه")" />
                            </MudItem>
                        }

                        <!-- Pattern: pattern selector + variable fields -->
                        @if (_smsType == SmsType.Pattern)
                        {
                            <MudItem xs="12">
                                <MudSelect T="string"
                                           Value="_selectedPatternCode"
                                           ValueChanged="@((string v) => OnPatternSelected(v))"
                                           Label="انتخاب پترن"
                                           Variant="Variant.Outlined"
                                           Disabled="@_loadingPatterns"
                                           HelperText="@(_loadingPatterns ? "در حال بارگذاری پترن‌ها..." : "")"
                                           AnchorOrigin="Origin.BottomLeft">
                                    @foreach (var p in _patterns)
                                    {
                                        <MudSelectItem Value="@p.PatternCode">
                                            @($"{p.PatternCode} {(!string.IsNullOrWhiteSpace(p.Title) ? $"— {p.Title}" : "")}")
                                            <MudChip T="string" Size="Size.Small" Variant="Variant.Filled"
                                                     Color="@(p.PatternStatus == "active" ? Color.Success : Color.Warning)"
                                                     Style="height:18px;font-size:0.65rem;margin-right:4px;">
                                                @p.PatternStatusFa
                                            </MudChip>
                                        </MudSelectItem>
                                    }
                                </MudSelect>
                            </MudItem>

                            @if (_selectedPattern != null)
                            {
                                <MudItem xs="12">
                                    <MudPaper Elevation="0" Style="background:#f8f9fa;border-radius:8px;padding:12px 16px;border:1px solid #e9ecef;">
                                        <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mb-1">پیش‌نمایش پترن:</MudText>
                                        <MudText Typo="Typo.body2" Style="white-space:pre-wrap;direction:rtl;">@_selectedPattern.PatternMessage</MudText>
                                    </MudPaper>
                                </MudItem>

                                @foreach (var v in _selectedPattern.Variable)
                                {
                                    <MudItem xs="12">
                                        <MudTextField Value="@GetVariableValue(v.Name)"
                                                      ValueChanged="@((string val) => SetVariableValue(v.Name, val))"
                                                      Label="@($"متغیر: {v.Name} ({v.Type})")"
                                                      Variant="Variant.Outlined"
                                                      Placeholder="@($"مقدار {v.Name} را وارد کنید")" />
                                    </MudItem>
                                }
                            }
                        }

                    </MudGrid>
                </MudCardContent>
                <MudCardActions>
                    <MudButton Variant="Variant.Filled" Color="Color.Primary"
                               StartIcon="@Icons.Material.Filled.Send"
                               OnClick="SendSms"
                               Disabled="@(_sending || !CanSend)"
                               FullWidth="true">
                        @(_sending ? "در حال ارسال..." : "ارسال پیامک")
                    </MudButton>
                </MudCardActions>
            </MudCard>
        </MudItem>

        <!-- ── SMS Log List ── -->
        <MudItem xs="12" md="7">
            <MudCard Elevation="2" Class="pico-card">
                <MudCardHeader>
                    <CardHeaderContent>
                        <MudText Typo="Typo.h6">
                            <MudIcon Icon="@Icons.Material.Filled.History" Class="ml-2" />
                            تاریخچه پیامک‌ها
                        </MudText>
                    </CardHeaderContent>
                    <CardHeaderActions>
                        <MudIconButton Icon="@Icons.Material.Filled.Refresh" OnClick="LoadLogsAsync" Size="Size.Small" />
                    </CardHeaderActions>
                </MudCardHeader>
                <MudCardContent Style="padding:0;">
                    @if (_loadingLogs)
                    {
                        <div style="padding:24px;text-align:center;">
                            <MudProgressCircular Indeterminate="true" Color="Color.Primary" Size="Size.Small" />
                        </div>
                    }
                    else if (!_logs.Any())
                    {
                        <div class="empty-state-sm" style="padding:40px;">
                            <MudIcon Icon="@Icons.Material.Filled.Inbox" Style="font-size:3rem;color:#d1d5db;" />
                            <span style="color:#9ca3af;margin-top:8px;">هنوز پیامکی ارسال نشده</span>
                        </div>
                    }
                    else
                    {
                        <div style="max-height:600px;overflow-y:auto;">
                            @foreach (var log in _logs)
                            {
                                <div style="display:flex;gap:12px;padding:14px 16px;border-bottom:1px solid var(--mud-palette-divider);align-items:flex-start;">
                                    <div style="width:38px;height:38px;border-radius:50%;background:#e3f2fd;display:flex;align-items:center;justify-content:center;flex-shrink:0;">
                                        <MudIcon Icon="@Icons.Material.Filled.Message" Style="color:#1565c0;font-size:1.1rem;" />
                                    </div>
                                    <div style="flex:1;min-width:0;">
                                        <div style="display:flex;align-items:center;gap:6px;margin-bottom:3px;">
                                            <span style="font-weight:700;font-size:0.875rem;" dir="ltr">@log.ContactPhone</span>
                                            @if (!string.IsNullOrWhiteSpace(log.ContactName))
                                            {
                                                <span style="font-size:0.78rem;color:#6b7280;">(@log.ContactName)</span>
                                            }
                                            <MudChip T="string" Size="Size.Small" Variant="Variant.Filled"
                                                     Color="@(log.Status == "sent" || log.Status == null ? Color.Success : Color.Warning)"
                                                     Style="height:18px;font-size:0.65rem;margin-right:auto;">
                                                @(log.Status == "sent" || log.Status == null ? "ارسال شد" : log.Status)
                                            </MudChip>
                                        </div>
                                        <div style="font-size:0.83rem;color:#374151;white-space:pre-wrap;overflow:hidden;text-overflow:ellipsis;max-height:56px;">@log.Message</div>
                                        <div style="display:flex;gap:8px;margin-top:4px;align-items:center;">
                                            <MudText Typo="Typo.caption" Color="Color.Secondary">
                                                @AppState.FormatDateTime(log.SentAt)
                                            </MudText>
                                            @if (!string.IsNullOrWhiteSpace(log.PatternCode))
                                            {
                                                <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined" Color="Color.Secondary" Style="height:18px;font-size:0.65rem;">
                                                    پترن: @log.PatternCode
                                                </MudChip>
                                            }
                                        </div>
                                    </div>
                                </div>
                            }
                        </div>
                    }
                </MudCardContent>
            </MudCard>
        </MudItem>

    </MudGrid>
</div>

@code {
    private enum SmsType { Webservice, Pattern }

    private record ContactSearchItem(string Id, string Phone, string Display);

    private SmsType _smsType = SmsType.Webservice;
    private string _toPhone = "";
    private string _messageText = "";
    private bool _sending;

    // Sender numbers
    private List<string> _senderNumbers = new();
    private string _smsSender = "";
    private bool _loadingNumbers;

    // Pattern
    private List<IpPanelPatternDto> _patterns = new();
    private bool _loadingPatterns;
    private string _selectedPatternCode = "";
    private IpPanelPatternDto? _selectedPattern;
    private Dictionary<string, string> _variableValues = new();

    // Contact search
    private ContactSearchItem? _selectedContact;

    // Logs
    private List<SmsLogDto> _logs = new();
    private bool _loadingLogs;

    private bool CanSend => !string.IsNullOrWhiteSpace(_toPhone) &&
        (_smsType == SmsType.Webservice
            ? !string.IsNullOrWhiteSpace(_messageText)
            : !string.IsNullOrWhiteSpace(_selectedPatternCode));

    protected override async Task OnInitializedAsync()
    {
        if (string.IsNullOrWhiteSpace(AppState.SmsApiKey))
            AppState.SmsApiKey = await SettingsService.GetAsync("Sms:ApiKey") ?? "";

        // Pre-fill sender from saved settings
        _smsSender = AppState.SmsSender;
        if (string.IsNullOrWhiteSpace(_smsSender))
            _smsSender = await SettingsService.GetAsync("Sms:Sender") ?? "";

        await Task.WhenAll(LoadLogsAsync(), LoadPatternsAsync(), LoadSenderNumbersAsync());
    }

    private async Task LoadSenderNumbersAsync()
    {
        if (string.IsNullOrWhiteSpace(AppState.SmsApiKey)) return;
        _loadingNumbers = true;
        StateHasChanged();
        try
        {
            _senderNumbers = (await SmsService.GetNumbersAsync(AppState.SmsApiKey)).ToList();
            // Keep saved sender visible even if not in list
            if (!string.IsNullOrWhiteSpace(_smsSender) && !_senderNumbers.Contains(_smsSender))
                _senderNumbers.Insert(0, _smsSender);
            // Auto-select if only one number or sender already matches
            if (_senderNumbers.Count == 1)
                _smsSender = _senderNumbers[0];
        }
        catch { }
        finally { _loadingNumbers = false; StateHasChanged(); }
    }

    private async Task LoadPatternsAsync()
    {
        if (string.IsNullOrWhiteSpace(AppState.SmsApiKey)) return;
        _loadingPatterns = true;
        try { _patterns = await SmsService.GetPatternsAsync(AppState.SmsApiKey); }
        catch { _patterns = new(); }
        finally { _loadingPatterns = false; StateHasChanged(); }
    }

    private async Task LoadLogsAsync()
    {
        _loadingLogs = true;
        StateHasChanged();
        try
        {
            _logs = await SmsLogService.GetLogsAsync();
        }
        catch (Exception ex)
        {
            _logs = new();
            Snackbar.Add($"خطا در بارگذاری تاریخچه: {ex.Message}", Severity.Warning);
        }
        finally
        {
            _loadingLogs = false;
            StateHasChanged();
        }
    }

    private async Task<IEnumerable<ContactSearchItem>> SearchContacts(string query, CancellationToken ct)
    {
        if (string.IsNullOrWhiteSpace(query) || query.Length < 2) return [];
        if (string.IsNullOrWhiteSpace(AppState.HubSpotApiKey))
        {
            AppState.HubSpotApiKey = await HubSpotService.GetApiKeyAsync() ?? "";
        }
        if (string.IsNullOrWhiteSpace(AppState.HubSpotApiKey)) return [];

        try
        {
            var contacts = await HubSpotService.SearchContactsAsync(AppState.HubSpotApiKey, query, 10);
            return contacts
                .Where(c => !string.IsNullOrWhiteSpace(c.MobilePhone) || !string.IsNullOrWhiteSpace(c.Phone))
                .Select(c => new ContactSearchItem(
                    c.Id,
                    c.MobilePhone ?? c.Phone ?? "",
                    $"{c.FirstName} {c.LastName}".Trim() + $" — {c.MobilePhone ?? c.Phone}"));
        }
        catch { return []; }
    }

    private void OnContactSelected(ContactSearchItem? item)
    {
        _selectedContact = item;
        if (item != null)
            _toPhone = item.Phone;
    }

    private void OnPatternSelected(string code)
    {
        _selectedPatternCode = code;
        _selectedPattern = _patterns.FirstOrDefault(p => p.PatternCode == code);
        _variableValues = new();
    }

    private string GetVariableValue(string name)
        => _variableValues.TryGetValue(name, out var v) ? v : "";

    private void SetVariableValue(string name, string value)
        => _variableValues[name] = value;

    private async Task SendSms()
    {
        if (!CanSend) return;
        _sending = true;
        try
        {
            Result result;
            string msgBody;
            string? patternCode = null;

            if (_smsType == SmsType.Webservice)
            {
                result = await SmsService.SendAsync(_toPhone, _messageText);
                msgBody = _messageText;
            }
            else
            {
                var patResult = await SmsService.SendPatternAsync(
                    AppState.SmsApiKey, _selectedPatternCode, _toPhone, _variableValues,
                    string.IsNullOrWhiteSpace(_smsSender) ? null : _smsSender);
                result = patResult.IsSuccess ? Result.Success() : Result.Failure(patResult.Error ?? "خطا");
                patternCode = _selectedPatternCode;

                // Build a human-readable message for the log
                msgBody = BuildPatternPreview();
            }

            if (result.IsSuccess)
            {
                var sender = await SettingsService.GetAsync("Sms:Sender") ?? "";
                await SmsLogService.SaveLogAsync(new SmsLogDto
                {
                    ContactHsId  = _selectedContact?.Id,
                    ContactPhone = _toPhone,
                    ContactName  = _selectedContact?.Display.Split("—")[0].Trim(),
                    Message      = msgBody,
                    SenderNumber = sender,
                    PatternCode  = patternCode,
                    Status       = "sent",
                    SentAt       = DateTime.UtcNow
                });

                // Log HubSpot note if contact known
                if (_selectedContact != null && !string.IsNullOrWhiteSpace(AppState.HubSpotApiKey))
                {
                    try
                    {
                        await HubSpotService.AddNoteAsync(
                            AppState.HubSpotApiKey,
                            $"پیامک ارسالی:\n{msgBody}",
                            null,
                            _selectedContact.Id);
                    }
                    catch { }
                }

                Snackbar.Add("پیامک با موفقیت ارسال شد ✓", Severity.Success);
                _messageText = "";
                _variableValues = new();
                _selectedContact = null;
                _toPhone = "";
                await LoadLogsAsync();
            }
            else
            {
                Snackbar.Add($"خطا در ارسال: {result.Error}", Severity.Error);
            }
        }
        finally { _sending = false; }
    }

    private string BuildPatternPreview()
    {
        if (_selectedPattern == null) return _selectedPatternCode;
        var msg = _selectedPattern.PatternMessage;
        foreach (var kv in _variableValues)
            msg = msg.Replace($"{_selectedPattern.Delimiter}{kv.Key}{_selectedPattern.Delimiter}", kv.Value);
        return msg;
    }
}
