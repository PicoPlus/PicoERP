@page "/daily-closing"
@inject IDailyClosingService ClosingService
@inject IBankTransferService BankTransferService
@inject IFinancialAccountService AccountService
@inject AppStateService AppState
@inject ISnackbar Snackbar
@inject IDialogService DialogService

<PageTitle>بستن روزانه — پیکو ERP</PageTitle>

<div class="pico-page" dir="rtl">
    <div class="page-header">
        <div>
            <MudText Typo="Typo.h4" Class="page-title">بستن روزانه</MudText>
            <MudText Typo="Typo.caption" Color="Color.Secondary">خلاصه مالی روز و ثبت بستن حساب</MudText>
        </div>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.LockClock"
                   OnClick="SaveClosing" Disabled="@(_saving || (_summary?.IsClosed == true))">
            @(_summary?.IsClosed == true ? "امروز بسته شده" : "ثبت بستن امروز")
        </MudButton>
    </div>

    @if (_summary == null)
    {
        <MudProgressLinear Indeterminate="true" Color="Color.Primary" Class="mb-4" />
    }
    else
    {
        <!-- Auto-computed summary strip -->
        <MudCard Elevation="2" Class="pico-card mb-4" Style="border-top:3px solid #1565C0;">
            <MudCardHeader>
                <CardHeaderContent>
                    <MudText Typo="Typo.h6">خلاصه خودکار امروز — @AppState.FormatDate(DateTime.Today)</MudText>
                </CardHeaderContent>
            </MudCardHeader>
            <MudCardContent>
                <MudGrid Spacing="3">
                    <MudItem xs="12" sm="3">
                        <StatCard Title="کل درآمد ثبت‌شده" Value="@AppState.FormatAmount(_summary.TotalIncomeRecorded)"
                                  Icon="@Icons.Material.Filled.TrendingUp" Color="#2E7D32" BgColor="#E8F5E9" />
                    </MudItem>
                    <MudItem xs="12" sm="3">
                        <StatCard Title="انتقال بانکی (کارت به کارت)" Value="@AppState.FormatAmount(_summary.AutoBankTransferTotal)"
                                  Icon="@Icons.Material.Filled.CompareArrows" Color="#1565C0" BgColor="#E3F2FD" />
                    </MudItem>
                    <MudItem xs="12" sm="3">
                        <StatCard Title="کل هزینه‌ها" Value="@AppState.FormatAmount(_summary.TotalExpense)"
                                  Icon="@Icons.Material.Filled.MoneyOff" Color="#C62828" BgColor="#FFEBEE" />
                    </MudItem>
                    <MudItem xs="12" sm="3">
                        <StatCard Title="سود خالص"
                                  Value="@AppState.FormatAmount(_summary.TotalIncomeRecorded - _summary.TotalExpense)"
                                  Icon="@Icons.Material.Filled.AccountBalance"
                                  Color="@(_summary.TotalIncomeRecorded >= _summary.TotalExpense ? "#1565C0" : "#C62828")"
                                  BgColor="@(_summary.TotalIncomeRecorded >= _summary.TotalExpense ? "#E3F2FD" : "#FFEBEE")" />
                    </MudItem>
                </MudGrid>

                <!-- Per-account breakdown -->
                @if (_summary.AccountBreakdown.Any())
                {
                    <MudDivider Class="my-3" />
                    <MudText Typo="Typo.subtitle2" Class="mb-2">خلاصه به تفکیک حساب</MudText>
                    <MudTable Items="_summary.AccountBreakdown" Dense="true" Hover="true" Elevation="0">
                        <HeaderContent>
                            <MudTh>حساب</MudTh>
                            <MudTh>نوع</MudTh>
                            <MudTh>درآمد</MudTh>
                            <MudTh>هزینه</MudTh>
                            <MudTh>خالص</MudTh>
                        </HeaderContent>
                        <RowTemplate>
                            <MudTd>@context.AccountName</MudTd>
                            <MudTd><MudText Typo="Typo.caption">@context.AccountType</MudText></MudTd>
                            <MudTd><span class="amount-positive">@AppState.FormatAmount(context.TotalIncome)</span></MudTd>
                            <MudTd><span class="amount-negative">@AppState.FormatAmount(context.TotalExpense)</span></MudTd>
                            <MudTd>
                                <strong class="@(context.TotalIncome - context.TotalExpense >= 0 ? "amount-positive" : "amount-negative")">
                                    @AppState.FormatAmount(context.TotalIncome - context.TotalExpense)
                                </strong>
                            </MudTd>
                        </RowTemplate>
                    </MudTable>
                }
            </MudCardContent>
        </MudCard>

        <!-- Closing entry form -->
        <MudCard Elevation="2" Class="pico-card mb-4" Style="border-top:3px solid #6A1B9A;">
            <MudCardHeader>
                <CardHeaderContent><MudText Typo="Typo.h6">اطلاعات بستن صندوق</MudText></CardHeaderContent>
            </MudCardHeader>
            <MudCardContent>
                <MudGrid Spacing="3" dir="rtl">
                    <MudItem xs="12" sm="6" md="3">
                        <MudNumericField @bind-Value="_dto.CashOnHand" Label="موجودی نقد (صندوق)" Variant="Variant.Outlined"
                                         Min="0" Adornment="Adornment.End" AdornmentText="تومان"
                                         HelperText="پول نقد موجود در صندوق هنگام بستن" />
                    </MudItem>
                    <MudItem xs="12" sm="6" md="3">
                        <MudNumericField @bind-Value="_dto.BankTransferIncome" Label="انتقال بانکی (کارت به کارت)" Variant="Variant.Outlined"
                                         Min="0" Adornment="Adornment.End" AdornmentText="تومان"
                                         HelperText="@($"محاسبه خودکار: {AppState.FormatAmount(_summary.AutoBankTransferTotal)} — جهت اصلاح وارد کنید")" />
                    </MudItem>
                    <MudItem xs="12" sm="6" md="3">
                        <MudNumericField @bind-Value="_dto.PosIncome" Label="دریافت کارتخوان (POS)" Variant="Variant.Outlined"
                                         Min="0" Adornment="Adornment.End" AdornmentText="تومان" />
                    </MudItem>
                    <MudItem xs="12" sm="6" md="3">
                        <MudNumericField @bind-Value="_dto.OnlineIncome" Label="خرید آنلاین / درگاه اینترنتی" Variant="Variant.Outlined"
                                         Min="0" Adornment="Adornment.End" AdornmentText="تومان" />
                    </MudItem>
                    <MudItem xs="12">
                        <MudPaper Elevation="0" Class="pa-3" Style="background:#F3E5F5; border-radius:8px; border:1px solid #CE93D8;">
                            <MudText Typo="Typo.body1" Style="font-weight:700; color:#6A1B9A;">
                                جمع کل دریافتی:
                                @AppState.FormatAmount(
                                    _dto.CashOnHand +
                                    (_dto.BankTransferIncome > 0 ? _dto.BankTransferIncome : _summary.AutoBankTransferTotal) +
                                    _dto.PosIncome + _dto.OnlineIncome)
                                تومان
                            </MudText>
                        </MudPaper>
                    </MudItem>
                    <MudItem xs="12">
                        <MudTextField @bind-Value="_dto.Notes" Label="توضیحات" Variant="Variant.Outlined" Lines="2" />
                    </MudItem>
                </MudGrid>
            </MudCardContent>
        </MudCard>
    }

    <!-- Closing history -->
    <MudCard Elevation="2" Class="pico-card">
        <MudCardHeader>
            <CardHeaderContent><MudText Typo="Typo.h6">تاریخچه بستن روزانه</MudText></CardHeaderContent>
        </MudCardHeader>
        <MudCardContent Class="pa-0">
            @if (_history.Any())
            {
                <MudTable Items="_history" Dense="true" Hover="true" Striped="true">
                    <HeaderContent>
                        <MudTh>تاریخ</MudTh>
                        <MudTh>نقدی</MudTh>
                        <MudTh>کارت به کارت</MudTh>
                        <MudTh>کارتخوان</MudTh>
                        <MudTh>آنلاین</MudTh>
                        <MudTh>کل درآمد</MudTh>
                        <MudTh>هزینه</MudTh>
                        <MudTh>سود</MudTh>
                        <MudTh>وضعیت</MudTh>
                        <MudTh>ثبت کننده</MudTh>
                    </HeaderContent>
                    <RowTemplate>
                        <MudTd dir="ltr">@AppState.FormatDate(context.Date)</MudTd>
                        <MudTd>@AppState.FormatAmount(context.CashOnHand)</MudTd>
                        <MudTd>@AppState.FormatAmount(context.BankTransferIncome)</MudTd>
                        <MudTd>@AppState.FormatAmount(context.PosIncome)</MudTd>
                        <MudTd>@AppState.FormatAmount(context.OnlineIncome)</MudTd>
                        <MudTd><span class="amount-positive">@AppState.FormatAmount(context.TotalIncome)</span></MudTd>
                        <MudTd><span class="amount-negative">@AppState.FormatAmount(context.TotalExpense)</span></MudTd>
                        <MudTd><strong class="@(context.Profit >= 0 ? "amount-positive" : "amount-negative")">@AppState.FormatAmount(context.Profit)</strong></MudTd>
                        <MudTd>
                            <MudChip T="string" Size="Size.Small" Color="@(context.IsFinalized ? Color.Success : Color.Warning)" Variant="Variant.Filled">
                                @(context.IsFinalized ? "نهایی" : "پیش‌نویس")
                            </MudChip>
                        </MudTd>
                        <MudTd><MudText Typo="Typo.caption">@(context.RegisteredBy ?? "-")</MudText></MudTd>
                    </RowTemplate>
                </MudTable>
            }
            else
            {
                <div class="empty-state-sm">
                    <MudIcon Icon="@Icons.Material.Filled.CalendarViewDay" />
                    <span>هیچ بستن روزانه‌ای ثبت نشده</span>
                </div>
            }
        </MudCardContent>
    </MudCard>
</div>

@code {
    private DailyClosingSummaryDto? _summary;
    private List<DailyClosingDto> _history = new();
    private CreateDailyClosingDto _dto = new();
    private bool _saving;

    protected override async Task OnInitializedAsync() => await LoadAsync();

    private async Task LoadAsync()
    {
        _summary = await ClosingService.GetTodaySummaryAsync(DateTime.Today);
        _history = await ClosingService.GetHistoryAsync();
        // Pre-fill POS from summary if not yet set
        if (_dto.PosIncome == 0 && _dto.CashOnHand == 0)
            _dto = new CreateDailyClosingDto { Date = DateTime.Today };
    }

    private async Task SaveClosing()
    {
        _saving = true;
        try
        {
            var result = await ClosingService.CloseAsync(_dto, AppState.CurrentUser?.DisplayName ?? "system");
            if (result.IsSuccess) { Snackbar.Add("بستن روز با موفقیت ثبت شد", Severity.Success); await LoadAsync(); }
            else Snackbar.Add(result.Error ?? "خطا", Severity.Error);
        }
        finally { _saving = false; }
    }
}
