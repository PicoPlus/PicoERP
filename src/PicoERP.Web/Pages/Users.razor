@page "/users"
@inject PicoERP.Infrastructure.Persistence.AppDbContext Db
@inject AppStateService AppState
@inject ISnackbar Snackbar
@inject IJSRuntime JS
@using Microsoft.EntityFrameworkCore
@using PicoERP.Domain.Entities
@using PicoERP.Domain.Enums

<PageTitle>کاربران — پیکو ERP</PageTitle>

<div class="pico-page" dir="rtl">
    <div class="page-header">
        <div>
            <MudText Typo="Typo.h4" Class="page-title">مدیریت کاربران</MudText>
            <MudText Typo="Typo.caption" Color="Color.Secondary">مشاهده و مدیریت حساب‌های کاربری سیستم</MudText>
        </div>
        <div class="header-actions">
            <MudButton Variant="Variant.Outlined" StartIcon="@Icons.Material.Filled.Print"
                       OnClick="@(async () => await JS.InvokeVoidAsync("window.print"))"
                       Class="no-print">چاپ</MudButton>
            <MudButton Variant="Variant.Filled" Color="Color.Primary"
                       StartIcon="@Icons.Material.Filled.PersonAdd"
                       OnClick="OpenAddDialog">کاربر جدید</MudButton>
        </div>
    </div>

    <!-- Summary -->
    <MudGrid Spacing="3" Class="mb-4">
        <MudItem xs="12" sm="4">
            <StatCard Title="کل کاربران" Value="@_users.Count.ToString()"
                      Icon="@Icons.Material.Filled.People" Color="#1565C0" BgColor="#E3F2FD" />
        </MudItem>
        <MudItem xs="12" sm="4">
            <StatCard Title="کاربران فعال" Value="@_users.Count(u => u.IsActive).ToString()"
                      Icon="@Icons.Material.Filled.VerifiedUser" Color="#2E7D32" BgColor="#E8F5E9" />
        </MudItem>
        <MudItem xs="12" sm="4">
            <StatCard Title="کاربران غیرفعال" Value="@_users.Count(u => !u.IsActive).ToString()"
                      Icon="@Icons.Material.Filled.PersonOff" Color="#C62828" BgColor="#FFEBEE" />
        </MudItem>
    </MudGrid>

    <!-- Users Table -->
    <MudCard Elevation="2" Class="pico-card">
        <MudCardHeader>
            <CardHeaderContent>
                <MudText Typo="Typo.h6">لیست کاربران</MudText>
            </CardHeaderContent>
            <CardHeaderActions>
                <MudTextField @bind-Value="_search" Placeholder="جستجو..." Variant="Variant.Outlined"
                              Adornment="Adornment.End" AdornmentIcon="@Icons.Material.Filled.Search"
                              Margin="Margin.Dense" Immediate="true"
                              Style="min-width:200px;" />
            </CardHeaderActions>
        </MudCardHeader>
        <MudCardContent Class="pa-0">
            @if (_loading)
            {
                <div class="loading-center"><MudProgressCircular Color="Color.Primary" Indeterminate="true" /></div>
            }
            else if (!_filtered.Any())
            {
                <div class="empty-state-sm">
                    <MudIcon Icon="@Icons.Material.Filled.PersonSearch" />
                    <span>کاربری یافت نشد</span>
                </div>
            }
            else
            {
                <MudTable Items="_filtered" Dense="true" Hover="true" Striped="true" Breakpoint="Breakpoint.Sm">
                    <HeaderContent>
                        <MudTh>#</MudTh>
                        <MudTh>نام نمایشی</MudTh>
                        <MudTh>نام کاربری</MudTh>
                        <MudTh>نقش</MudTh>
                        <MudTh>ایمیل</MudTh>
                        <MudTh>آخرین ورود</MudTh>
                        <MudTh>وضعیت</MudTh>
                        <MudTh Class="no-print">عملیات</MudTh>
                    </HeaderContent>
                    <RowTemplate>
                        <MudTd><MudText Typo="Typo.caption">@context.Id</MudText></MudTd>
                        <MudTd>
                            <div style="display:flex;align-items:center;gap:8px;">
                                <MudAvatar Size="Size.Small" Color="Color.Primary" Style="font-size:0.75rem;">
                                    @context.DisplayName.Substring(0, 1)
                                </MudAvatar>
                                <MudText>@context.DisplayName</MudText>
                            </div>
                        </MudTd>
                        <MudTd dir="ltr" style="text-align:right !important;">@context.Username</MudTd>
                        <MudTd>
                            <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined"
                                     Color="@GetRoleColor(context.Role)">
                                @GetRolePersian(context.Role)
                            </MudChip>
                        </MudTd>
                        <MudTd>@(context.Email ?? "—")</MudTd>
                        <MudTd>
                            @if (context.LastLoginAt.HasValue)
                            {
                                <MudText Typo="Typo.caption">@AppState.FormatDate(context.LastLoginAt.Value)</MudText>
                            }
                            else
                            {
                                <MudText Typo="Typo.caption" Color="Color.Secondary">—</MudText>
                            }
                        </MudTd>
                        <MudTd>
                            <MudChip T="string" Size="Size.Small"
                                     Color="@(context.IsActive ? Color.Success : Color.Error)"
                                     Variant="Variant.Filled">
                                @(context.IsActive ? "فعال" : "غیرفعال")
                            </MudChip>
                        </MudTd>
                        <MudTd Class="no-print">
                            <MudTooltip Text="@(context.IsActive ? "غیرفعال‌سازی" : "فعال‌سازی")">
                                <MudIconButton Icon="@(context.IsActive ? Icons.Material.Filled.Block : Icons.Material.Filled.CheckCircle)"
                                               Size="Size.Small"
                                               Color="@(context.IsActive ? Color.Error : Color.Success)"
                                               OnClick="@(() => ToggleActive(context))" />
                            </MudTooltip>
                        </MudTd>
                    </RowTemplate>
                </MudTable>
            }
        </MudCardContent>
    </MudCard>
</div>

@code {
    private List<AppUser> _users = new();
    private string _search = "";
    private bool _loading = true;

    private IEnumerable<AppUser> _filtered =>
        string.IsNullOrWhiteSpace(_search)
            ? _users
            : _users.Where(u =>
                u.DisplayName.Contains(_search, StringComparison.OrdinalIgnoreCase) ||
                u.Username.Contains(_search, StringComparison.OrdinalIgnoreCase) ||
                (u.Email?.Contains(_search, StringComparison.OrdinalIgnoreCase) ?? false));

    protected override async Task OnInitializedAsync()
    {
        await LoadUsers();
    }

    private async Task LoadUsers()
    {
        _loading = true;
        _users = await Db.Users.AsNoTracking().OrderBy(u => u.Id).ToListAsync();
        _loading = false;
    }

    private async Task ToggleActive(AppUser user)
    {
        var dbUser = await Db.Users.FindAsync(user.Id);
        if (dbUser == null) return;
        dbUser.IsActive = !dbUser.IsActive;
        dbUser.UpdatedAt = DateTime.UtcNow;
        await Db.SaveChangesAsync();
        Snackbar.Add(dbUser.IsActive ? "کاربر فعال شد" : "کاربر غیرفعال شد", Severity.Success);
        await LoadUsers();
    }

    private void OpenAddDialog()
    {
        Snackbar.Add("امکان افزودن کاربر در نسخه بعدی اضافه می‌شود", Severity.Info);
    }

    private static string GetRolePersian(UserRole role) => role switch
    {
        UserRole.SystemAdmin => "مدیر سیستم",
        UserRole.Manager => "مدیر",
        UserRole.Accountant => "حسابدار",
        UserRole.Employee => "کارمند",
        _ => "نامشخص"
    };

    private static Color GetRoleColor(UserRole role) => role switch
    {
        UserRole.SystemAdmin => Color.Error,
        UserRole.Manager => Color.Warning,
        UserRole.Accountant => Color.Primary,
        _ => Color.Default
    };
}
