<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <location path="." inheritInChildApplications="false">
    <system.webServer>

      <!-- Serve static files directly via IIS (faster than passing through Kestrel) -->
      <staticContent>
        <mimeMap fileExtension=".wasm"  mimeType="application/wasm" />
        <mimeMap fileExtension=".br"    mimeType="application/octet-stream" />
        <mimeMap fileExtension=".gz"    mimeType="application/octet-stream" />
      </staticContent>

      <handlers>
        <!-- Remove all other handlers so only AspNetCoreModuleV2 handles requests -->
        <remove name="WebDAV" />
        <remove name="ExtensionlessUrlHandler-Integrated-4.0" />
        <add name="aspNetCore"
             path="*"
             verb="*"
             modules="AspNetCoreModuleV2"
             resourceType="Unspecified" />
      </handlers>

      <!--
        processPath : "dotnet" when ASP.NET Core Runtime is installed on the server.
                      Use the full exe path for self-contained deploys.
        hostingModel: "inprocess"  – runs inside the IIS worker process (best performance).
                      Use "outofprocess" if Plesk/IIS does not support in-process hosting.
        stdoutLogEnabled: set to true only when debugging startup failures,
                          then flip back to false.
      -->
      <aspNetCore processPath="dotnet"
                  arguments=".\PicoERP.Web.dll"
                  stdoutLogEnabled="false"
                  stdoutLogFile=".\logs\stdout"
                  hostingModel="inprocess">
        <environmentVariables>
          <environmentVariable name="ASPNETCORE_ENVIRONMENT" value="Production" />
        </environmentVariables>
      </aspNetCore>

      <!-- Prevent IIS from blocking PUT / DELETE verbs -->
      <modules>
        <remove name="WebDAVModule" />
      </modules>

      <!-- Custom error pages — let ASP.NET Core handle errors, not IIS -->
      <httpErrors existingResponse="PassThrough" />

    </system.webServer>
  </location>
</configuration>
